; Engine configuration file.
; Edit with Godot 4.x.

config_version=5

[application]
config/name="Yinqi Horror Engine"
run/main_scene="res://scenes/MapDebug.tscn"
config/features=PackedStringArray("4.2", "Mobile")
config/icon="res://icon.svg"

[autoload]
EventBus="*res://src/core/EventBus.gd"
GameState="*res://src/core/GameState.gd"
DataRegistry="*res://src/core/DataRegistry.gd"
EngineHub="*res://src/core/EngineHub.gd"
WorldSim="*res://src/world_sim/WorldSim.gd"
LocationController="*res://src/locations/LocationController.gd"
MapSkinDirector="*res://src/maps/MapSkinDirector.gd"
ViewpointDirector="*res://src/viewpoints/ViewpointDirector.gd"
HotspotController="*res://src/hotspots/HotspotController.gd"
InteractionController="*res://src/interactions/InteractionController.gd"
NPCMemory="*res://src/npc_memory/NPCMemory.gd"
NPCBehaviorPlanner="*res://src/npc_behavior/NPCBehaviorPlanner.gd"
ClueStore="*res://src/clues/ClueStore.gd"
StorylineEngine="*res://src/storylines/StorylineEngine.gd"
FolkloreRules="*res://src/folklore_rules/FolkloreRules.gd"
HorrorDirector="*res://src/horror_director/HorrorDirector.gd"
RenderingDirector="*res://src/rendering/RenderingDirector.gd"
BreathDirector="*res://src/audio/BreathDirector.gd"
GhostGenerator="*res://src/ghost_generator/GhostGenerator.gd"
NarrativeEngine="*res://src/narrative/NarrativeEngine.gd"

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/handheld/orientation=1
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]
renderer/rendering_method="mobile"
textures/canvas_textures/default_texture_filter=0
